<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor">
            <AppThemeBinding Light="{StaticResource SurfaceLight_Light}" Dark="{StaticResource SurfaceLight_Dark}" />
        </Setter>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor">
            <AppThemeBinding Light="{StaticResource Surface_Light}" Dark="{StaticResource Surface_Dark}" />
        </Setter>
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow">
            <Shadow Radius="8" Opacity="0.08" Offset="0,2" />
        </Setter>
    </Style>

    <Style x:Key="HeadingStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource TextPrimary_Light}" Dark="{StaticResource TextPrimary_Dark}" />
        </Setter>
    </Style>

    <Style x:Key="SubheadingStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource TextSecondary_Light}" Dark="{StaticResource TextSecondary_Dark}" />
        </Setter>
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource TextPrimary_Light}" Dark="{StaticResource TextPrimary_Dark}" />
        </Setter>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor">
            <AppThemeBinding Light="{StaticResource TextMuted_Light}" Dark="{StaticResource TextMuted_Dark}" />
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style x:Key="ChipStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
    </Style>

</ResourceDictionary>
